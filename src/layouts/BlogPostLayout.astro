---
import type { ImageMetadata } from 'astro';
import Layout from './Layout.astro';
import 'katex/dist/katex.min.css';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	tags: string[];
	cover?: ImageMetadata;
}

const { title, description, pubDate, updatedDate, tags, cover } = Astro.props;

function formatDate(date: Date) {
	return date.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Layout
	title={`${title} — Блог`}
	description={description}
	image={cover?.src}
	type="article"
	publishedTime={pubDate}
	modifiedTime={updatedDate}
>
	<main>
		<a class="back" href="/blog">← Ко всем постам</a>

		<div class="post-header">
			<span class="eyebrow">
				{formatDate(pubDate)}
				{updatedDate && ` · обновлено ${formatDate(updatedDate)}`}
			</span>
			<h1>{title}</h1>
			{
				tags.length > 0 && (
					<div class="tags">
						{tags.map((tag) => (
							<a class="tag" href={`/blog/tags/${tag}/`}>
								{tag}
							</a>
						))}
					</div>
				)
			}
		</div>

		<div class="content">
			<slot />
		</div>
	</main>
</Layout>

<style>
	main {
		max-width: 720px;
		margin: 8vh auto 0;
		padding: 16px;
	}

	.back {
		display: inline-block;
		margin-bottom: 2.5em;
		color: var(--text);
		font-size: 14px;
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.back:hover {
		color: var(--ink);
	}

	.post-header {
		margin-bottom: 2.5em;
	}

	.eyebrow {
		display: block;
		font-size: 14px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--accent);
		margin: 0 0 0.6em;
	}

	h1 {
		font-size: 36px;
		line-height: 1.25;
		color: var(--ink);
		margin: 0 0 0.8em;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.tag {
		padding: 6px 14px;
		border: 1px solid var(--border);
		border-radius: 999px;
		font-size: 14px;
		color: var(--text);
		text-decoration: none;
		transition:
			color 0.2s ease,
			border-color 0.2s ease;
	}

	.tag:hover {
		color: var(--accent);
		border-color: var(--accent);
	}

	.content {
		color: var(--text);
		font-size: 19px;
		line-height: 1.7;
	}

	.content :global(h2) {
		font-size: 26px;
		font-weight: 600;
		color: var(--ink);
		margin: 1.8em 0 0.6em;
	}

	.content :global(h3) {
		font-size: 21px;
		font-weight: 600;
		color: var(--ink);
		margin: 1.6em 0 0.5em;
	}

	.content :global(p) {
		margin: 0 0 1.2em;
	}

	.content :global(a) {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	.content :global(a:hover) {
		color: var(--accent-deep);
	}

	.content :global(ul),
	.content :global(ol) {
		margin: 0 0 1.2em;
		padding-left: 1.4em;
	}

	.content :global(li) {
		margin-bottom: 0.4em;
	}

	.content :global(blockquote) {
		margin: 1.5em 0;
		padding-left: 1em;
		border-left: 2px solid var(--border);
		color: var(--text);
		font-style: italic;
	}

	.content :global(code) {
		font-family: var(--font-mono);
		background: rgba(0, 0, 0, 0.05);
		padding: 2px 6px;
		border-radius: 4px;
		font-size: 0.85em;
	}

	.content :global(pre) {
		padding: 18px;
		border-radius: 12px;
		overflow-x: auto;
		margin: 0 0 1.5em;
	}

	.content :global(pre code) {
		background: none;
		padding: 0;
		font-size: 0.9em;
	}

	.content :global(img) {
		max-width: 100%;
		height: auto;
		border-radius: 8px;
	}

	.content :global(hr) {
		border: none;
		border-top: 1px solid var(--border);
		margin: 2.5em 0;
	}

	.content :global(strong) {
		color: var(--ink);
		font-weight: 700;
	}

	@media screen and (max-width: 640px) {
		h1 {
			font-size: 28px;
		}
	}
</style>

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Обо мне — Артём" description="Страница в разработке.">
	<main>
		<h1>Обо мне</h1>
		<p>Я ещё думаю, что здесь написать. Загляните позже.</p>
		<a class="back" href="/">← На главную</a>
	</main>
</Layout>

<style>
	main {
		max-width: 860px;
		margin: 8vh auto 0;
		padding: 16px;
	}

	h1 {
		font-size: 36px;
		margin: 0 0 0.6em;
		color: var(--ink);
	}

	p {
		color: var(--text);
		font-size: 19px;
		line-height: 1.7;
		margin: 0 0 1.5em;
	}

	.back {
		color: var(--text);
		font-size: 14px;
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.back:hover {
		color: var(--ink);
	}
</style>

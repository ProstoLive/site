---
import Layout from '../layouts/Layout.astro';

function escapeHtml(str: string) {
	return str.replace(
		/[&<>"]/g,
		(c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c]!,
	);
}

// "---" -> длинное тире, "--" -> среднее, одиночный "-" не трогаем
function typographicDashes(str: string) {
	return str.replace(/---/g, '—').replace(/--/g, '–');
}

// [текст](url) -> <a href="url">текст</a>
function formatDetails(str: string) {
	const withDashes = typographicDashes(escapeHtml(str));
	return withDashes.replace(
		/\[([^\]]+)\]\((https?:\/\/[^\s)]+)\)/g,
		'<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>',
	);
}

